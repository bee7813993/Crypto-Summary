# Crypto-Summary 環境変数設定例
# このファイルを .env にコピーして実際のキーを入力してください。
# .env は .gitignore に含まれているためリポジトリには含まれません。

# =====================================================================
# 【マルチユーザー / Docker】起動時に必須なのは以下の 2 つだけ
# =====================================================================

# セッション署名キー（必ず変更: python -c "import secrets; print(secrets.token_hex(32))"）
SECRET_KEY=change-this-to-a-random-64-char-hex-string

# ユーザーDBを格納するディレクトリ（Docker volume のマウント先）
# これを設定するとマルチユーザーモード（Google ログイン）になる。
DATA_DIR=/data

# =====================================================================
# 以下はすべて「初回セットアップウィザード」（ログイン前に表示）から
# Web 画面で設定できます。.env に書いておけばウィザードを省略できます。
# どちらでも可。env に書いた値が常に優先されます。
# =====================================================================

# --- Google OAuth 2.0（マルチユーザーでログインに必須）---
# Google Cloud Console → APIとサービス → 認証情報 → OAuth 2.0 クライアントID で取得
# リダイレクトURI に ${BASE_URL}/auth/callback を登録すること
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# アプリの公開URL（末尾スラッシュなし）。OAuth リダイレクトURI の組み立てに使う。
BASE_URL=

# 暗号化マスター鍵（Web/CLI から登録する取引所・ウォレットAPIキーの暗号化に使用）
# 生成: crypto-summary account gen-key（ウィザードの「生成する」ボタンでも可）
# 紛失すると登録済みキーを復号できなくなる。
CS_SECRET_KEY=

# 管理者の Google アカウント（カンマ区切り・マルチユーザーモードのみ）
# ここに記載したメールのユーザーだけが、Web の「システム設定」から
# 全ユーザー共通のスキャン用 API キー（Etherscan / Helius）を編集できる。
ADMIN_EMAILS=

# =====================================================================
# CoinGecko Demo API キー（任意・無料）
# https://www.coingecko.com/en/api/pricing で「Demo」プランに登録 → API キー発行。
# 設定するとレート制限が 30 req/分 に緩和され、価格・推移グラフの取得が安定・高速化する。
# 未設定でもキーなしで動作するが、429（レート制限）が出やすくなる。読み取り専用。
# =====================================================================
COINGECKO_API_KEY=your-coingecko-demo-api-key



# =====================================================================
# 取引所・ウォレットの API キー（以下はすべて任意）
#
# 推奨: 取引所キー / ウォレットのスキャン用キーは、Web の「インポート」画面
#       から登録してください（ユーザーごとに暗号化して保存されます）。
#       その場合、下記の .env への記載は不要です（CS_SECRET_KEY のみ必要）。
#
# 下記は CLI 利用時、またはシングルユーザーで全体共通キーを使う場合の
# フォールバックです。
# =====================================================================

# --- bitFlyer API ---
# 権限: 「資産残高を見る」「取引履歴を見る」のみ付与すること
# 出金・送付・注文の権限は絶対に付与しないこと（セキュリティ要件）
BITFLYER_API_KEY=your_api_key_here
BITFLYER_API_SECRET=your_api_secret_here

# --- Etherscan V2 API（EVMマルチチェーン: Ethereum/Arbitrum/Polygon/Base/Optimism）---
# https://etherscan.io/myapikey で無料発行。読み取り専用（出金権限は存在しない）。
# 1つのキーで全対応チェーンを取得できる。全ユーザー共通のシステムキー。
# Web の「システム設定」（管理者のみ）から登録すると、この env より優先される。
# 注: 無料プランは Base / Optimism 非対応（有料プランが必要）。
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# --- Helius API（Solana ウォレット）---
# https://dev.helius.xyz で無料発行。読み取り専用（送金権限は不要）。
# 1つのキーで Solana メインネットの取引履歴を取得できる。全ユーザー共通のシステムキー。
# Web の「システム設定」（管理者のみ）から登録すると、この env より優先される。
# （Solscan 無料プランは取引履歴 API が使えないため Helius を採用）
HELIUS_API_KEY=your_helius_api_key_here
